NACHKLANG_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-64-random-hex-or-base64
DATABASE_URL=postgresql://nachklang:nachklang-dev-password@postgres:5432/nachklang?schema=public
WEBAUTHN_RP_ID=localhost

# Mail transport selection: "graph" (default, Microsoft Graph) or "smtp" (any SMTP server).
NACHKLANG_MAIL_TRANSPORT=graph

# Microsoft Graph mail transport (used when NACHKLANG_MAIL_TRANSPORT=graph)
MICROSOFT_TENANT_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_CLIENT_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_CLIENT_CERTIFICATE_PRIVATE_KEY_PATH=/run/secrets/microsoft-graph-private-key.pem
MICROSOFT_CLIENT_CERTIFICATE_THUMBPRINT=replace-with-sha1-certificate-thumbprint
# Used when NACHKLANG_GRAPH_AUTH_MODE=client-secret. Certificate mode is recommended.
MICROSOFT_CLIENT_SECRET=dev-only-client-secret
GRAPH_MAILBOX_UPN=nachklang@example.com
NACHKLANG_VISIBLE_EMAIL=nachklang@example.com

# SMTP mail transport (used when NACHKLANG_MAIL_TRANSPORT=smtp). The From/Reply-To
# identity reuses NACHKLANG_VISIBLE_EMAIL above.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Bot / abuse protection (Cloudflare Turnstile, optional but recommended in prod).
# Free; create a site at https://dash.cloudflare.com/?to=/:account/turnstile to get the
# keys. When TURNSTILE_SECRET_KEY is set, the OTP-send endpoint requires a valid token,
# and the signup form shows the widget (TURNSTILE_SITE_KEY). Leave both unset to disable.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Local Docker database bootstrap
POSTGRES_DB=nachklang
POSTGRES_USER=nachklang
POSTGRES_PASSWORD=nachklang-dev-password

# Local-dev OTP capture: write each outgoing OTP/email to this TSV file instead of
# relying on real mail delivery. Lets you complete sign-up/onboarding locally without
# configured Microsoft Graph. Leave unset in production.
# NACHKLANG_MAIL_CAPTURE_PATH=/tmp/mail-capture.tsv

# --- Production backup (see docs/ops/backup-restore.md) ---
# age recipient PUBLIC key. Generate the keypair OFFLINE with `age-keygen -o age-identity.txt`;
# keep age-identity.txt in your password manager and NEVER place it on the server. The host can
# create backups with this public key but can never decrypt them.
NACHKLANG_BACKUP_AGE_RECIPIENT=age1replace-with-your-age-public-key
# Host directory that receives encrypted backups (Phase 2 syncs this to the Hetzner Storage Box).
NACHKLANG_BACKUP_DIR=/srv/nachklang-backups
# GFS retention (optional overrides; defaults shown).
NACHKLANG_BACKUP_KEEP_DAILY=7
NACHKLANG_BACKUP_KEEP_WEEKLY=4
NACHKLANG_BACKUP_KEEP_MONTHLY=6
# Optional: URL the systemd failure unit POSTs to if a backup run fails (e.g. a chat webhook).
# A failed run is always logged to the journal; the webhook is only an extra alert. Leave unset
# to disable. Set in the host .env, not here.
# BACKUP_ALERT_WEBHOOK=https://example.com/webhook
