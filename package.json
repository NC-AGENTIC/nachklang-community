    "@zxcvbn-ts/core": "3.0.4",
    "@zxcvbn-ts/language-common": "3.0.4",
    "@zxcvbn-ts/language-de": "3.0.2",
    "better-auth": "1.6.11",
    "libsodium-wrappers-sumo": "0.8.4",
    "lucide-react": "1.16.0",
    "next": "16.2.6",
    "next-intl": "^4.12.0",
    "nodemailer": "^8.0.7",
    "pg": "8.21.0",
    "qrcode": "1.5.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
