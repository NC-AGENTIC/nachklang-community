    "@types/nodemailer": "^8.0.0",
    "@types/pg": "8.20.0",
    "@types/qrcode": "1.5.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "29.1.1",
